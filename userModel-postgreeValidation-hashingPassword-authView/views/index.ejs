<%- include('../views/partials/navbar.ejs') %> <%-
include('../views/partials/header.ejs') %>

<style>
  body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: linear-gradient(to top, #87ceeb, #ffffff);
  }

  /* Navbar */
  .navbar {
    display: flex;
    justify-content: space-between;
    padding: 15px 40px;
    background: rgba(0, 0, 0, 0.6);
    color: white;
  }

  .navbar a {
    color: white;
    text-decoration: none;
    margin-left: 20px;
  }

  /* Main Section */
  .hero {
    height: 90vh;
    position: relative;
    overflow: hidden;
  }

  /* Sun */
  .sun {
    width: 100px;
    height: 100px;
    background: yellow;
    border-radius: 50%;
    position: absolute;
    top: 50px;
    right: 80px;
  }

  /* Ground */
  .ground {
    position: absolute;
    bottom: 0;
    width: 100%;
    height: 200px;
    background: #3cb371;
  }

  /* House */
  .house {
    position: absolute;
    bottom: 200px;
    left: 40%;
  }

  .base {
    width: 150px;
    height: 100px;
    background: #ffcc99;
    position: relative;
  }

  .roof {
    width: 0;
    height: 0;
    border-left: 75px solid transparent;
    border-right: 75px solid transparent;
    border-bottom: 80px solid #8b0000;
    position: absolute;
    top: -80px;
  }

  .door {
    width: 30px;
    height: 50px;
    background: brown;
    position: absolute;
    bottom: 0;
    left: 60px;
  }

  /* Tree */
  .tree {
    position: absolute;
    bottom: 200px;
    left: 20%;
  }

  .trunk {
    width: 20px;
    height: 80px;
    background: #8b4513;
  }

  .leaves {
    width: 80px;
    height: 80px;
    background: green;
    border-radius: 50%;
    position: relative;
    top: -40px;
    left: -30px;
  }

  /* Text */
  .text {
    position: absolute;
    top: 30%;
    left: 10%;
    color: #333;
  }

  .text h1 {
    font-size: 50px;
    margin: 0;
  }

  .text p {
    font-size: 18px;
  }
</style>
<div class="hero">
  <div class="sun"></div>

  <div class="text">
    <h1>Welcome to My Village</h1>
    <p>Peaceful life, green nature, and fresh air</p>
  </div>

  <!-- Tree -->
  <div class="tree">
    <div class="trunk"></div>
    <div class="leaves"></div>
  </div>

  <!-- House -->
  <div class="house">
    <div class="roof"></div>
    <div class="base">
      <div class="door"></div>
    </div>
  </div>

  <!-- Ground -->
  <div class="ground"></div>
</div>

<%- include('../views/partials/footer.ejs') %>
